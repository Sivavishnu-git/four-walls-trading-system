# ============================================
# LiveTrading Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# ============================================
# Upstox API Credentials
# ============================================
# Get these from: https://upstox.com/developer/apps
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here

# ============================================
# Server Configuration
# ============================================
PROXY_SERVER_PORT=3000
FRONTEND_PORT=5173

# ============================================
# API Endpoints
# ============================================
UPSTOX_API_BASE_URL=https://api-v2.upstox.com
UPSTOX_WEBSOCKET_URL=wss://api-v2.upstox.com/feed/market-data-feed/v3

# ============================================
# Trading Configuration
# ============================================
# Default instrument for monitoring
DEFAULT_INSTRUMENT_KEY=NSE_FO|49229

# Polling interval in milliseconds (for REST API polling)
POLLING_INTERVAL=2000

# OI capture interval in milliseconds (2 minutes = 120000)
OI_CAPTURE_INTERVAL=120000

# ============================================
# Risk Management (Optional)
# ============================================
# Maximum position size (number of lots)
MAX_POSITION_SIZE=10

# Maximum order quantity (number of units)
MAX_ORDER_QUANTITY=650

# Enable paper trading mode (true/false)
PAPER_TRADING_MODE=true

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
ENABLE_API_LOGGING=true

# ============================================
# Development
# ============================================
NODE_ENV=development
