# Upstox API Credentials
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here

# OAuth Redirect URI
# Development: http://localhost:3000/api/auth/callback
# Production: https://your-app.onrender.com/api/auth/callback
UPSTOX_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Access Token (optional - will be generated via OAuth)
UPSTOX_ACCESS_TOKEN=your_access_token_here
VITE_UPSTOX_ACCESS_TOKEN=your_access_token_here

# Instrument Key for Nifty Future
# Find the current month's contract using /api/tools/find-nifty-future
VITE_INSTRUMENT_KEY=NSE_FO|49229

# Environment
NODE_ENV=development

# Port (optional - defaults to 3000)
PORT=3000

# Production Settings (for deployment platforms)
# These are usually set automatically by the platform
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
