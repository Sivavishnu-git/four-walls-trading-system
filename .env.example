# Upstox API Credentials
# For a separate LOCAL app only: copy env.local.template to .env.local and put keys there
# (see env.local.template). .env.local overrides this file and is gitignored.
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here

# OAuth Redirect URI — MUST match EXACTLY what you saved in the Upstox developer
# dashboard (App → Redirect URL). Same scheme, host, path, and trailing slash rules.
#
# If your dashboard only has e.g. https://myapp.example.com/api/auth/callback then set
# UPSTOX_REDIRECT_URI to that exact string. The proxy must be reachable at that URL
# when you log in (so either deploy the API there, or add a second redirect URL in
# Upstox for local dev: http://localhost:3000/api/auth/callback and tunnel if needed).
#
# Local API (default):  http://localhost:3000/api/auth/callback  (use PORT below)
# Cloudflare tunnel:     https://<your-host>/api/auth/callback
UPSTOX_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Where the browser is sent after login (token is appended as ?token=...).
# Dev: Vite dev server (usually 5173).
FRONTEND_URI=http://localhost:5173

# Access Token (optional - will be generated via OAuth)
UPSTOX_ACCESS_TOKEN=your_access_token_here
VITE_UPSTOX_ACCESS_TOKEN=your_access_token_here

# Instrument Key for Nifty Future
# Find the current month's contract using /api/tools/find-nifty-future
VITE_INSTRUMENT_KEY=NSE_FO|49229

# Environment
NODE_ENV=development

# Port (optional - defaults to 3000)
PORT=3000

# Production Settings (for deployment platforms)
# These are usually set automatically by the platform
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
